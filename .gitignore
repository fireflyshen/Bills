# ==========================
# 操作系统垃圾 (双机党必加)
# ==========================
# Mac
log/
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ==========================
# IDE & 编辑器
# ==========================
# VS Code (通常不提交个人配置，除非是团队强制规范)
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains (PyCharm/WebStorm)
.idea/

# ==========================
# Node.js / 前端
# ==========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/
coverage/


# ==========================
# Python (如果你用了Python脚本)
# ==========================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt

# ==========================
# 安全与隐私 (绝对不能漏)
# ==========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# 但要保留示例文件
!.env.example

# ==========================
# 媒体与大文件 (防止 GH001 错误)
# ==========================
*.mp4
*.mp3
*.mov
*.avi
*.wav
*.flac
*.zip
*.tar.gz

# ==========================
# 项目特定
# ==========================
# 假设你的上传文件都在这里，直接忽略整个文件夹
uploads/
temp/
logs/
*.log
